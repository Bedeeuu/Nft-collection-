{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ghostmind.local/schemas/module_manifest.schema.json",
  "title": "GhostMind Module Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "module_id",
    "name",
    "version",
    "owner",
    "status",
    "dependencies",
    "interfaces",
    "security",
    "observability",
    "replay"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "module_id": { "type": "string", "pattern": "^[a-z0-9_\\-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "owner": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["planned", "design", "implemented", "tested", "operational", "deprecated", "archived"] },
    "orl": { "type": "integer", "minimum": 0, "maximum": 9 },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "interfaces": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "api": { "type": "array", "items": { "type": "string" } },
        "events": { "type": "array", "items": { "type": "string" } },
        "storage": { "type": "array", "items": { "type": "string" } }
      }
    },
    "security": {
      "type": "object",
      "required": ["classification", "requires_vault", "requires_governance"],
      "properties": {
        "classification": { "type": "string", "enum": ["public", "internal", "confidential", "restricted"] },
        "requires_vault": { "type": "boolean" },
        "requires_governance": { "type": "boolean" }
      }
    },
    "observability": {
      "type": "object",
      "required": ["metrics", "logs", "healthcheck"],
      "properties": {
        "metrics": { "type": "boolean" },
        "logs": { "type": "boolean" },
        "healthcheck": { "type": "boolean" }
      }
    },
    "replay": {
      "type": "object",
      "required": ["required", "coverage_target"],
      "properties": {
        "required": { "type": "boolean" },
        "coverage_target": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    }
  }
}
